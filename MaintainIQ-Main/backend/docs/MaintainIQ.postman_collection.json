        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.data.token) {",
                  "    pm.environment.set(\"accessToken\", jsonData.data.token);",
                  "    console.log(\"Saved accessToken environment variable!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
